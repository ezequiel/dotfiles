#!/usr/bin/env bash
# Refresh the cursor provider's model list in an opencode JSONC config by
# querying `cursor-agent --list-models`. Restart opencode after running.
#
# Usage:
#   refresh-cursor-models PATH
#
# ponytail: in-place edits a JSONC file by replacing the "models": {...} block
# inside provider.cursor. Assumes exactly one such block exists; preserves the
# surrounding indentation.

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $(basename "$0") PATH" >&2
  exit 2
fi

CONFIG="$1"

if [[ ! -f "$CONFIG" ]]; then
  echo "config not found: $CONFIG" >&2
  exit 1
fi

if ! command -v cursor-agent >/dev/null; then
  echo "cursor-agent not on PATH" >&2
  exit 1
fi

raw=$(cursor-agent --list-models 2>/dev/null)

CURSOR_MODELS_RAW="$raw" python3 - "$CONFIG" <<'PY'
import json, os, re, sys, pathlib

config_path = pathlib.Path(sys.argv[1])
raw = os.environ["CURSOR_MODELS_RAW"]

models = {}
for line in raw.splitlines():
    m = re.match(r"^([a-z0-9][a-z0-9._-]*)\s+-\s+(.+?)\s*$", line, re.I)
    if not m:
        continue
    mid, name = m.group(1), m.group(2)
    entry = {"name": name}
    if "thinking" in mid:
        entry["reasoning"] = True
    models[mid] = entry

if not models:
    sys.exit("no models parsed from cursor-agent --list-models")

text = config_path.read_text()

# Locate the one "models": { ... } block.
start_re = re.compile(r'(?P<indent>[ \t]*)"models"\s*:\s*\{')
starts = list(start_re.finditer(text))
if len(starts) != 1:
    sys.exit(f'expected exactly 1 "models" key, found {len(starts)}')

start = starts[0]
indent = start.group("indent")

# Brace-match to find the end (the value may contain nested objects).
i = start.end() - 1  # position of opening '{'
depth = 0
end = None
while i < len(text):
    c = text[i]
    if c == "{":
        depth += 1
    elif c == "}":
        depth -= 1
        if depth == 0:
            end = i + 1
            break
    i += 1
if end is None:
    sys.exit('unbalanced braces around "models" block')

# Pretty-print and re-indent to match the surrounding block.
body = json.dumps(models, indent=2)
lines = body.splitlines()
# First line ('{') keeps its position right after "models": .
# Subsequent lines get prefixed with the captured indent.
rendered_lines = [lines[0]] + [indent + line for line in lines[1:]]
new_block = f'"models": ' + "\n".join(rendered_lines)

config_path.write_text(text[: start.start() + len(indent)] + new_block + text[end:])
print(f"wrote {len(models)} models to {config_path}")
PY

echo "restart opencode to pick up changes"
