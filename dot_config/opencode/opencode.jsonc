{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "permission": {
    "bash": {
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "rm -rf *": "ask"
    }
  },
  "autoupdate": false,
  "instructions": ["{env:XDG_CONFIG_HOME}/opencode/output-styles/linus-torvalds.md"],
  "default_agent": "plan",
  "experimental": {
    "openTelemetry": false
  },
  "share": "disabled",
  "snapshot": false,
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": true
    }
  }
}
