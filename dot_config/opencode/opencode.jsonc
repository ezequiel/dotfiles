{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": false,
  "instructions": ["{env:XDG_CONFIG_HOME}/opencode/output-styles/linus-torvalds.md"],
  "agent": {
    "plan": {
      "variant": "max"
    },
    "build": {
      "variant": "max"
    }
  },
  "default_agent": "plan",
  "experimental": {
    "openTelemetry": false
  },
  "share": "disabled",
  "snapshot": false,
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": true
    }
  }
}
