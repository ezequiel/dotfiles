{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "tokyonight",
  "keybinds": {
    "leader": "\\",

    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",
    "session_interrupt": "escape",

    "command_list": "<leader>c",
    "model_list": "<leader>m",
    "session_list": "<leader>l",
    "session_new": "<leader>n",
    "session_rename": "<leader>r",
    "messages_copy": "<leader>y",

    "messages_next": "alt+j",
    "messages_previous": "alt+k",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "ctrl+shift+g",
    "messages_last": "ctrl+g",
    "messages_line_up": "ctrl+p",
    "messages_line_down": "ctrl+n",

    "history_previous": "up",
    "history_next": "down",

    "input_undo": "ctrl+z",
    "input_redo": "ctrl+shift+z",

    "terminal_suspend": "none",
    "terminal_title_toggle": "none",

    "session_compact": "none",
  },
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "mouse": false
}
